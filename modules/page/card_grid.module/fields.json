  {
    "id": "enable-module-heading",
    "name": "enable_module_heading",
    "label": "Enable Module Heading",
    "inline_help_text": "Enables/disables the ability to add a heading, summary text, and a CTA or link above the module.",
    "required": false,
    "locked": false,
    "display": "toggle",
    "type": "boolean",
    "display_width": null,
    "default": false
  },
  {
    "id": "module-heading-group",
    "name": "module_heading",
    "label": "Section header",
    "required": false,
    "locked": false,
    "visibility": {
      "controlling_field": "enable-module-heading",
      "controlling_value_regex": "true",
      "operator": "EQUAL"
    },
    "children": [
      {
        "id": "heading",
        "name": "heading",
        "label": "Headline",
        "required": true,
        "locked": false,
        "allow_new_line": false,
        "type": "text",
        "display_width": null,
        "default": "Card Grid Heading",
        "inline_help_text": "Main heading for this section. Keep concise for best readability.",
        "placeholder": "Enter headline text"
      },
      {
        "id": "heading-type",
        "name": "heading_type",
        "label": "Heading level",
        "inline_help_text": "Determines the size of the heading text with H1 being the largest and H6 being the smallest.",
        "required": true,
        "locked": false,
        "display": "select",
        "choices": [
          [
            "h1",
            "H1"
          ],
          [
            "h2",
            "H2"
          ],
          [
            "h3",
            "H3"
          ],
          [
            "h4",
            "H4"
          ],
          [
            "h5",
            "H5"
          ],
          [
            "h6",
            "H6"
          ]
        ],
        "multiple": false,
        "type": "choice",
        "display_width": null,
        "default": "h2"
      },
      {
        "id": "summary",
        "name": "summary",
        "label": "Summary text",
        "required": false,
        "locked": false,
        "enabled_features": [
          "underline",
          "link",
          "bold",
          "italic"
        ],
        "type": "richtext",
        "display_width": null,
        "inline_help_text": "Optional supporting text that appears below the headline."
      },
      {
        "id": "add-link-cta",
        "name": "add_link_cta_",
        "label": "Add Link/CTA?",
        "inline_help_text": "Enables/disables the ability to add a CTA or link to follow the heading or heading text if populated.",
        "required": false,
        "locked": false,
        "display": "toggle",
        "type": "boolean",
        "display_width": null,
        "default": false
      },
      {
        "id": "button-group",
        "name": "button",
        "label": "Link / CTA",
        "inline_help_text": "Settings for populating and customising a link or CTA element.",
        "required": false,
        "locked": false,
        "visibility": {
          "controlling_field": "add-link-cta",
          "controlling_value_regex": "true",
          "operator": "EQUAL"
        },
        "children": [
          {
            "id": "button-type",
            "name": "button_type",
            "label": "Button type",
            "required": true,
            "locked": false,
            "display": "select",
            "choices": [
              [
                "none",
                "None"
              ],
              [
                "link",
                "Link"
              ],
              [
                "cta",
                "CTA"
              ]
