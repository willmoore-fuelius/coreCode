[
  {
    "name": "section_number",
    "label": "Section Number",
    "type": "text",
    "default": "01",
    "help_text": "Section number displayed above the heading for visual ordering.",
    "placeholder": "e.g. 01"
  },
  {
    "name": "heading",
    "label": "Heading",
    "type": "text",
    "default": "Web Development",
    "help_text": "Main heading for this service section.",
    "placeholder": "e.g. Web Development"
  },
  {
    "name": "description",
    "label": "Description",
    "type": "text",
    "default": "We don't just build websites; we architect digital growth engines. Our bespoke development process prioritizes speed, SEO, and user experience to ensure your site converts visitors into advocates.",
    "help_text": "Service description paragraph. 2-3 sentences recommended."
  },
  {
    "name": "image",
    "label": "Image",
    "type": "image",
    "default": {
      "src": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=500&fit=crop&crop=center",
      "alt": "Service image",
      "width": 800,
      "height": 500
    },
    "help_text": "Landscape image recommended (800x500px minimum). Image appears rotated with a coloured backdrop."
  },
  {
    "name": "image_accent_colour",
    "label": "Image Accent Colour",
    "type": "choice",
    "choices": [
      [
        "primary",
        "Purple"
      ],
      [
        "secondary",
        "Pink"
      ],
      [
        "highlight",
        "Green"
      ]
    ],
    "default": "primary",
    "help_text": "Colour of the decorative backdrop behind the image."
  },
  {
    "name": "layout",
    "label": "Layout",
    "type": "choice",
    "choices": [
      [
        "image-left",
        "Image Left"
      ],
      [
        "image-right",
        "Image Right"
      ]
    ],
    "default": "image-left",
    "help_text": "Choose which side the image appears on."
  },
  {
    "name": "content_type",
    "label": "Content Type",
    "type": "choice",
    "choices": [
      [
        "feature_list",
        "Feature List"
      ],
      [
        "stat_grid",
        "Stat Grid"
      ],
      [
        "inline_quote",
        "Testimonial Quote"
      ]
    ],
    "default": "feature_list",
    "help_text": "Choose the content block displayed below the description."
  },
  {
    "name": "feature_list",
    "label": "Feature List",
    "type": "group",
    "occurrence": {
      "min": 1,
      "max": 8,
      "default": 3
    },
    "default": [
      {
        "text": "Headless CMS Architectures"
      },
      {
        "text": "Performance Optimized Frontend"
      },
      {
        "text": "Enterprise-grade Security"
      }
    ],
    "help_text": "Checklist items displayed when Feature List content type is selected. Each item shows a checkmark icon.",
    "children": [
      {
        "name": "text",
        "label": "Feature Text",
        "type": "text",
        "default": "",
        "help_text": "Feature or benefit text.",
        "placeholder": "e.g. Headless CMS Architectures"
      }
    ]
  },
  {
    "name": "stat_grid",
    "label": "Stat Grid",
    "type": "group",
    "occurrence": {
      "min": 1,
      "max": 4,
      "default": 2
    },
    "default": [
      {
        "value": "98%",
        "label": "Adoption Rate"
      },
      {
        "value": "45%",
        "label": "Lead Increase"
      }
    ],
    "help_text": "Statistics displayed when Stat Grid content type is selected.",
    "children": [
      {
        "name": "value",
        "label": "Value",
        "type": "text",
        "default": "",
        "help_text": "The headline stat figure.",
        "placeholder": "e.g. 98%"
      },
      {
        "name": "stat_label",
        "label": "Label",
        "type": "text",
        "default": "",
        "help_text": "Short label describing the stat.",
        "placeholder": "e.g. Adoption Rate"
      }
    ]
  },
  {
    "name": "inline_quote",
    "label": "Testimonial Quote",
    "type": "group",
    "children": [
      {
        "name": "quote",
        "label": "Quote",
        "type": "text",
        "default": "\"The inbound strategy GrowthArchitect implemented became our primary revenue driver within 6 months.\"",
        "help_text": "Quote text. Include quotation marks if desired."
      },
      {
        "name": "attribution",
        "label": "Attribution",
        "type": "text",
        "default": "\u00e2\u20ac\u201d Head of Marketing, Global SaaS",
        "help_text": "Who said this quote.",
        "placeholder": "e.g. \u00e2\u20ac\u201d Head of Marketing, Acme Corp"
      }
    ],
    "help_text": "Testimonial quote displayed when Testimonial Quote content type is selected."
  },
  {
    "name": "cta_text",
    "label": "CTA Text",
    "type": "text",
    "default": "Learn more",
    "help_text": "CTA button label.",
    "placeholder": "e.g. Learn more"
  },
  {
    "name": "cta_link",
    "label": "CTA Link",
    "type": "link",
    "default": {
      "url": {
        "href": "#",
        "type": "EXTERNAL"
      },
      "open_in_new_tab": false,
      "no_follow": false
    },
    "help_text": "Where should the CTA button link to?"
  },
  {
    "name": "module_heading",
    "label": "Module Heading",
    "type": "group",
    "children": [
      {
        "name": "heading",
        "label": "Heading",
        "type": "text",
        "default": ""
      },
      {
        "name": "heading_type",
        "label": "Heading Level",
        "type": "choice",
        "choices": [
          [
            "h2",
            "H2"
          ],
          [
            "h3",
            "H3"
          ],
          [
            "h4",
            "H4"
          ]
        ],
        "default": "h2"
      },
      {
        "name": "subheading",
        "label": "Subheading",
        "type": "text",
        "default": ""
      }
    ]
  },
  {
    "name": "scrollid",
    "label": "Scroll ID",
    "type": "text",
    "default": "",
    "help_text": "Optional anchor ID for in-page navigation links."
  },
  {
    "name": "style",
    "label": "Style",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "name": "spacing_alignment",
        "label": "Spacing",
        "type": "group",
        "children": [
          {
            "name": "spacing",
            "label": "Spacing",
            "type": "group",
            "children": [
              {
                "name": "mobile",
                "label": "Mobile",
                "type": "group",
                "children": [
                  {
                    "name": "padding_top",
                    "label": "Top Spacing",
                    "type": "number",
                    "default": 40,
                    "min": 0,
                    "max": 500,
                    "step": 1,
                    "suffix": "px",
                    "help_text": "Top spacing in pixels for mobile devices"
                  },
                  {
                    "name": "padding_bottom",
                    "label": "Bottom Spacing",
                    "type": "number",
                    "default": 40,
                    "min": 0,
                    "max": 500,
                    "step": 1,
                    "suffix": "px",
                    "help_text": "Bottom spacing in pixels for mobile devices"
                  }
                ]
              },
              {
                "name": "desktop",
                "label": "Desktop",
                "type": "group",
                "children": [
                  {
                    "name": "padding_top",
                    "label": "Top Spacing",
                    "type": "number",
                    "default": 96,
                    "min": 0,
                    "max": 500,
                    "step": 1,
                    "suffix": "px",
                    "help_text": "Top spacing in pixels for desktop devices"
                  },
                  {
                    "name": "padding_bottom",
                    "label": "Bottom Spacing",
                    "type": "number",
                    "default": 96,
                    "min": 0,
                    "max": 500,
                    "step": 1,
                    "suffix": "px",
                    "help_text": "Bottom spacing in pixels for desktop devices"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "background_colour",
        "label": "Background Colour",
        "type": "choice",
        "choices": [
          [
            "default",
            "Default"
          ],
          [
            "surface",
            "Surface"
          ],
          [
            "primary",
            "Primary"
          ]
        ],
        "default": "default",
        "help_text": "Section background colour."
      }
    ]
  }
]